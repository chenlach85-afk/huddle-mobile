# Clasiko Mobile App — Required Environment Variables
#
# For local dev (pnpm dev), copy this to .env.local and fill in values.
# For EAS builds, these are already set in eas.json (except EXPO_PUBLIC_DOMAIN).
#
# IMPORTANT: Replace EXPO_PUBLIC_DOMAIN with your deployed API server domain
# (e.g. your Replit deployment URL, without https:// and without trailing slash).
# The API server must be publicly reachable from the mobile app.

# Supabase — get from Supabase dashboard > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://rwyhsmnrxisbldnrahpo.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJ3eWhzbW5yeGlzYmxkbnJhaHBvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMzc1MjEsImV4cCI6MjA5NDYxMzUyMX0.gdc5w3vUmq9QfzIH8wHPc9LRkSMbCXeUhkOiIjcB4cg

# Your deployed API server domain (no https://, no trailing slash)
# Example: my-clasiko-app.replit.app
# For development in Replit, this is set automatically.
EXPO_PUBLIC_DOMAIN=YOUR_DEPLOYED_API_DOMAIN_HERE
